<%- include('../partials/header', { title: 'Daftar Produk' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-box-seam"></i> Daftar Produk</h4>
  <a href="/products/create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Tambah Produk</a>
</div>

<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show">
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (products.length === 0) { %>
      <p class="text-muted text-center py-5">Belum ada produk. <a href="/products/create">Tambah sekarang</a>.</p>
    <% } else { %>
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Nama</th>
            <th>Kategori</th>
            <th class="text-end">Harga</th>
            <th class="text-center">Stok</th>
            <th class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((p, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td class="fw-semibold"><%= p.name %></td>
              <td><span class="badge bg-secondary"><%= p.category || '-' %></span></td>
              <td class="text-end">Rp <%= Number(p.price).toLocaleString('id-ID') %></td>
              <td class="text-center">
                <span class="badge <%= p.stock > 0 ? 'bg-success' : 'bg-danger' %>">
                  <%= p.stock %>
                </span>
              </td>
              <td class="text-center">
                <a href="/products/<%= p.id %>/edit" class="btn btn-sm btn-outline-warning me-1">
                  <i class="bi bi-pencil"></i>
                </a>
                <form action="/products/<%= p.id %>?_method=DELETE" method="POST" class="d-inline"
                      onsubmit="return confirm('Hapus produk <%= p.name %>?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
