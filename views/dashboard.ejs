<%- include('partials/header', { title: 'Dashboard' }) %>

<div class="row g-4 mb-4">
  <!-- Stat cards -->
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm text-white bg-primary">
      <div class="card-body d-flex align-items-center gap-3">
        <i class="bi bi-receipt fs-1"></i>
        <div>
          <div class="small">Total Transaksi</div>
          <div class="fs-3 fw-bold"><%= summary.total_transactions %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm text-white bg-success">
      <div class="card-body d-flex align-items-center gap-3">
        <i class="bi bi-cash-coin fs-1"></i>
        <div>
          <div class="small">Total Pendapatan</div>
          <div class="fs-3 fw-bold">Rp <%= Number(summary.total_revenue).toLocaleString('id-ID') %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm text-white bg-info">
      <div class="card-body d-flex align-items-center gap-3">
        <i class="bi bi-calendar-day fs-1"></i>
        <div>
          <div class="small">Pendapatan Hari Ini</div>
          <div class="fs-3 fw-bold">Rp <%= Number(todayRevenue.today_revenue).toLocaleString('id-ID') %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm text-white bg-warning">
      <div class="card-body d-flex align-items-center gap-3">
        <i class="bi bi-box-seam fs-1"></i>
        <div>
          <div class="small">Total Produk</div>
          <div class="fs-3 fw-bold"><%= totalProducts %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-clock-history"></i> Transaksi Terbaru
      </div>
      <div class="card-body p-0">
        <% if (recent.length === 0) { %>
          <p class="text-muted text-center py-4">Belum ada transaksi.</p>
        <% } else { %>
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>#</th>
                <th>Tanggal</th>
                <th>Kasir</th>
                <th class="text-end">Total</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% recent.forEach(tx => { %>
                <tr>
                  <td><%= tx.id %></td>
                  <td><%= tx.created_at %></td>
                  <td><%= tx.cashier %></td>
                  <td class="text-end">Rp <%= Number(tx.total).toLocaleString('id-ID') %></td>
                  <td><a href="/transactions/<%= tx.id %>" class="btn btn-sm btn-outline-primary">Detail</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
      <div class="card-footer bg-white text-end">
        <a href="/transactions" class="btn btn-sm btn-primary">Lihat Semua</a>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-header bg-white fw-semibold"><i class="bi bi-lightning-charge"></i> Aksi Cepat</div>
      <div class="card-body d-grid gap-2">
        <a href="/pos" class="btn btn-success btn-lg"><i class="bi bi-cart-plus"></i> Buka Kasir</a>
        <a href="/products/create" class="btn btn-outline-primary"><i class="bi bi-plus-circle"></i> Tambah Produk</a>
        <a href="/products" class="btn btn-outline-secondary"><i class="bi bi-list-ul"></i> Daftar Produk</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
