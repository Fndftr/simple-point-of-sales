<%- include('../partials/header', { title: 'Riwayat Transaksi' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-receipt"></i> Riwayat Transaksi</h4>
  <a href="/pos" class="btn btn-success"><i class="bi bi-plus-lg"></i> Transaksi Baru</a>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (transactions.length === 0) { %>
      <p class="text-muted text-center py-5">Belum ada transaksi.</p>
    <% } else { %>
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Tanggal</th>
            <th>Kasir</th>
            <th class="text-end">Total</th>
            <th class="text-end">Bayar</th>
            <th class="text-end">Kembalian</th>
            <th class="text-center">Detail</th>
          </tr>
        </thead>
        <tbody>
          <% transactions.forEach(tx => { %>
            <tr>
              <td><%= tx.id %></td>
              <td><%= tx.created_at %></td>
              <td><%= tx.cashier %></td>
              <td class="text-end fw-semibold text-success">Rp <%= Number(tx.total).toLocaleString('id-ID') %></td>
              <td class="text-end">Rp <%= Number(tx.payment).toLocaleString('id-ID') %></td>
              <td class="text-end">Rp <%= Number(tx.change).toLocaleString('id-ID') %></td>
              <td class="text-center">
                <a href="/transactions/<%= tx.id %>" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-eye"></i>
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
