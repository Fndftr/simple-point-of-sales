<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> – Simple POS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/"><i class="bi bi-shop"></i> Simple POS</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link <%= path === '/' ? 'active' : '' %>" href="/"><i class="bi bi-speedometer2"></i> Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= path.startsWith('/products') ? 'active' : '' %>" href="/products"><i class="bi bi-box-seam"></i> Produk</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= path === '/pos' ? 'active' : '' %>" href="/pos"><i class="bi bi-cart3"></i> Kasir</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= path.startsWith('/transactions') ? 'active' : '' %>" href="/transactions"><i class="bi bi-receipt"></i> Transaksi</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Content -->
  <div class="container-fluid py-4">
    <%- body %>
  </div>

  <footer class="text-center text-muted py-3 border-top mt-4">
    <small>&copy; <%= new Date().getFullYear() %> Simple POS &mdash; Express.js MVC</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
