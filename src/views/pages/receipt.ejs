<%- include('../partials/head', { pageTitle, currentUser }) %>
<section class="page-header">
  <div>
    <span class="eyebrow">Struk</span>
    <h1><%= transaction.invoiceNumber %></h1>
    <p>Detail transaksi terbaru.</p>
  </div>
  <a class="button ghost" href="/transactions/new">Transaksi Baru</a>
</section>
<section class="panel receipt">
  <div class="receipt-head">
    <div>
      <strong>Invoice</strong>
      <div><%= transaction.invoiceNumber %></div>
    </div>
    <div>
      <strong>Kasir</strong>
      <div><%= transaction.user?.name || '-' %></div>
    </div>
    <div>
      <strong>Tanggal</strong>
      <div><%= new Date(transaction.createdAt).toLocaleString('id-ID') %></div>
    </div>
  </div>
  <table>
    <thead>
      <tr><th>Produk</th><th>Qty</th><th>Harga</th><th>Subtotal</th></tr>
    </thead>
    <tbody>
      <% transaction.items.forEach((item) => { %>
        <tr>
          <td><%= item.product?.name || '-' %></td>
          <td><%= item.quantity %></td>
          <td>Rp <%= Number(item.price).toLocaleString('id-ID') %></td>
          <td>Rp <%= (Number(item.price) * item.quantity).toLocaleString('id-ID') %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <div class="receipt-total">
    <div><span>Metode</span><strong><%= transaction.paymentMethod %></strong></div>
    <div><span>Total</span><strong>Rp <%= Number(transaction.totalAmount).toLocaleString('id-ID') %></strong></div>
    <div><span>Cash</span><strong><%= transaction.cashReceived ? 'Rp ' + Number(transaction.cashReceived).toLocaleString('id-ID') : '-' %></strong></div>
    <div><span>Kembalian</span><strong><%= transaction.changeAmount ? 'Rp ' + Number(transaction.changeAmount).toLocaleString('id-ID') : '-' %></strong></div>
  </div>
</section>
<%- include('../partials/footer') %>
