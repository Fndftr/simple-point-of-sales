<%- include('../partials/head', { pageTitle, currentUser }) %>
<section class="page-header">
  <div>
    <span class="eyebrow">User</span>
    <h1>Manajemen pengguna</h1>
    <p>Buat akun admin dan kasir dari dashboard.</p>
  </div>
</section>
<section class="panel form-grid">
  <h2>Tambah User</h2>
  <% if (error) { %><div class="alert error"><%= error %></div><% } %>
  <form class="grid-form" method="post" action="/users">
    <label><span>Nama</span><input name="name" required></label>
    <label><span>Username</span><input name="username" required></label>
    <label><span>Password</span><input name="password" type="password" required></label>
    <label><span>Role</span>
      <select name="role">
        <option value="KASIR">KASIR</option>
        <option value="SUPERADMIN">SUPERADMIN</option>
      </select>
    </label>
    <div class="full"><button class="button primary" type="submit">Simpan</button></div>
  </form>
</section>
<section class="panel">
  <div class="panel-head">
    <h2>Daftar User</h2>
    <span class="muted"><%= users.length %> akun</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Nama</th><th>Username</th><th>Role</th><th>Dibuat</th></tr>
      </thead>
      <tbody>
        <% users.forEach((user) => { %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.username %></td>
            <td><%= user.role %></td>
            <td><%= new Date(user.createdAt).toLocaleString('id-ID') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/footer') %>
