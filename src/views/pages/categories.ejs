<%- include('../partials/head', { pageTitle, currentUser }) %>
<section class="page-header">
  <div>
    <span class="eyebrow">Kategori</span>
    <h1>Master kategori</h1>
    <p>Atur kategori produk agar katalog lebih rapi.</p>
  </div>
</section>
<section class="panel form-grid">
  <h2>Tambah Kategori</h2>
  <% if (error) { %><div class="alert error"><%= error %></div><% } %>
  <form class="grid-form" method="post" action="/categories">
    <label><span>Nama</span><input name="name" required></label>
    <label><span>Deskripsi</span><input name="description"></label>
    <div class="full"><button class="button primary" type="submit">Simpan</button></div>
  </form>
</section>
<section class="panel">
  <div class="panel-head">
    <h2>Daftar Kategori</h2>
    <span class="muted"><%= categories.length %> item</span>
  </div>
  <div class="stack">
    <% categories.forEach((category) => { %>
      <article class="list-card">
        <div>
          <strong><%= category.name %></strong>
          <div class="muted"><%= category.description || 'Tidak ada deskripsi' %></div>
        </div>
        <span class="pill"><%= category.products.length %> produk</span>
      </article>
    <% }) %>
  </div>
</section>
<%- include('../partials/footer') %>
