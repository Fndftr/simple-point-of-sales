<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle || 'POS' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/main.css" />
  </head>
  <body>
    <div class="bg-glow bg-glow-left"></div>
    <div class="bg-glow bg-glow-right"></div>
    <header class="topbar">
      <div class="brand">
        <a href="/" class="brand-mark">POS</a>
        <div>
          <div class="brand-title">Point of Sale</div>
          <div class="brand-subtitle">Express MVC + API</div>
        </div>
      </div>
      <nav class="nav">
        <% if (currentUser) { %>
          <a href="/dashboard">Dashboard</a>
          <a href="/products">Produk</a>
          <a href="/transactions/new">Kasir</a>
          <% if (currentUser.role === 'SUPERADMIN') { %>
            <a href="/categories">Kategori</a>
            <a href="/users">User</a>
            <a href="/transactions">Transaksi</a>
            <a href="/reports/sales">Laporan</a>
            <a href="/stock-adjustments">Stok</a>
          <% } %>
          <a href="/logout" class="nav-action">Logout</a>
        <% } else { %>
          <a href="/login" class="nav-action">Login</a>
        <% } %>
      </nav>
    </header>
    <main class="shell">
